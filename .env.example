# Server
PORT=3000
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d
DB_PATH=./curbside.db

# SMS (mock by default — set these to activate Twilio)
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Video (jitsi = free, no keys needed)
VIDEO_PROVIDER=jitsi
JITSI_DOMAIN=meet.jit.si
DAILY_API_KEY=
DAILY_DOMAIN=

# AI — set AI_PROVIDER=claude and paste your key below to enable real AI.
# Leave as 'mock' to run without a key.
AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Email (mock by default — set SMTP to activate)
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@curbside.au

# MBS billing: 'seconds' = demo/testing (a 6s call = first PES tier),
# 'minutes' = production (per the MBS factsheet: 6 min = first tier)
BILLING_TIME_UNIT=minutes

# Medicare claiming channel: 'mock' (simulated) or 'tyro' (Tyro Health / Medipass)
# Get an API key + confirm base URL/endpoints at https://docs.tyrohealth.com
CLAIMING_PROVIDER=mock
TYRO_API_KEY=
TYRO_BASE_URL=https://api.medipass.io
